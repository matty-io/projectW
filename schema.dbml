Project whatsapp_tool {
  database_type: "PostgreSQL"
  Note: "Canonical DBML for the WhatsApp Marketing Tool schema."
}

Enum plan_type {
  starter
  pro
  agency
}

Enum workspace_role {
  admin
  agent
  marketing
}

Enum contact_status {
  subscribed
  unsubscribed
  blocked
}

Enum contact_source {
  imported
  inbound
  bot
  manual
}

Enum quality_rating {
  GREEN
  YELLOW
  RED
}

Enum template_category {
  MARKETING
  UTILITY
  AUTHENTICATION
}

Enum template_status {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
}

Enum message_direction {
  inbound
  outbound
}

Enum message_type {
  text
  template
  image
  document
  audio
  video
}

Enum message_status {
  sent
  delivered
  read
  failed
}

Enum conversation_status {
  open
  resolved
  bot
}

Enum campaign_status {
  draft
  scheduled
  sending
  sent
  failed
}

Enum campaign_contact_status {
  pending
  sent
  delivered
  read
  failed
}

Table organizations {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(100) [not null]
  slug varchar(50) [not null, unique]
  plan plan_type [not null, default: 'starter']
  plan_expires_at timestamptz
  razorpay_customer_id varchar(100)
  razorpay_subscription_id varchar(100)
  created_at timestamptz [not null, default: `now()`]
}

Table users {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  email varchar(255) [not null]
  name varchar(100) [not null]
  password_hash text [not null]
  is_org_owner boolean [not null, default: false]
  is_active boolean [not null, default: true]
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (organization_id, email) [unique, name: "users_org_email_idx"]
    (organization_id) [name: "users_org_idx"]
  }
}

Table workspaces {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  name varchar(100) [not null]
  slug varchar(50) [not null]
  timezone varchar(50) [not null, default: 'Asia/Kolkata']
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (organization_id, slug) [unique, name: "workspaces_org_slug_idx"]
    (organization_id) [name: "workspaces_org_idx"]
  }
}

Table workspace_members {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  user_id uuid [not null, ref: > users.id]
  role workspace_role [not null, default: 'agent']
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id, user_id) [unique, name: "workspace_members_ws_user_idx"]
    (user_id) [name: "workspace_members_user_idx"]
  }
}

Table wa_business_accounts {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, unique, ref: > workspaces.id]
  meta_business_portfolio_id varchar(100)
  waba_id varchar(100) [not null, unique]
  display_name varchar(100)
  access_token text [not null]
  business_verified boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
}

Table wa_phone_numbers {
  id uuid [pk, default: `gen_random_uuid()`]
  waba_id uuid [not null, ref: > wa_business_accounts.id]
  workspace_id uuid [not null, ref: > workspaces.id]
  phone_number varchar(20) [not null]
  phone_number_id varchar(100) [not null, unique]
  display_name varchar(100)
  quality_rating quality_rating [default: 'GREEN']
  messaging_limit int [default: 1000]
  is_default boolean [not null, default: false]
  is_connected boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (waba_id) [name: "wa_phone_numbers_waba_idx"]
    (workspace_id) [name: "wa_phone_numbers_ws_idx"]
  }
}

Table contacts {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  phone varchar(20) [not null]
  name varchar(100)
  email varchar(255)
  status contact_status [not null, default: 'subscribed']
  source contact_source [not null, default: 'manual']
  attributes jsonb [default: '{}']
  last_seen_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id, phone) [unique, name: "contacts_ws_phone_idx"]
    (workspace_id, status) [name: "contacts_ws_status_idx"]
    (workspace_id) [name: "contacts_ws_idx"]
  }
}

Table tags {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  name varchar(50) [not null]
  color varchar(7) [default: '#3B82F6']
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id, name) [unique, name: "tags_ws_name_idx"]
  }
}

Table contact_tags {
  contact_id uuid [not null, ref: > contacts.id, pk]
  tag_id uuid [not null, ref: > tags.id, pk]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (tag_id) [name: "contact_tags_tag_idx"]
  }
}

Table lists {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  name varchar(100) [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id) [name: "lists_ws_idx"]
  }
}

Table list_contacts {
  list_id uuid [not null, ref: > lists.id, pk]
  contact_id uuid [not null, ref: > contacts.id, pk]

  Indexes {
    (contact_id) [name: "list_contacts_contact_idx"]
  }
}

Table templates {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  waba_id uuid [not null, ref: > wa_business_accounts.id]
  meta_template_id varchar(100)
  name varchar(100) [not null]
  category template_category [not null]
  language varchar(10) [not null, default: 'en_US']
  status template_status [not null, default: 'DRAFT']
  components jsonb [not null, default: '[]']
  rejection_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (waba_id, name) [unique, name: "templates_waba_name_idx"]
    (workspace_id, status) [name: "templates_ws_status_idx"]
  }
}

Table conversations {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  phone_number_id uuid [not null, ref: > wa_phone_numbers.id]
  contact_id uuid [not null, ref: > contacts.id]
  assigned_to uuid [ref: > users.id]
  status conversation_status [not null, default: 'open']
  last_message_at timestamptz
  last_customer_message_at timestamptz
  is_read boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (phone_number_id, contact_id) [unique, name: "conversations_phone_contact_idx"]
    (workspace_id, status, last_message_at) [name: "conversations_ws_status_time_idx"]
    (contact_id) [name: "conversations_contact_idx"]
    (assigned_to) [name: "conversations_assigned_idx"]
  }
}

Table messages {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null, ref: > conversations.id]
  workspace_id uuid [not null, ref: > workspaces.id]
  phone_number_id uuid [not null, ref: > wa_phone_numbers.id]
  wa_message_id varchar(100) [unique]
  direction message_direction [not null]
  type message_type [not null, default: 'text']
  content jsonb [not null, default: '{}']
  status message_status
  sent_by uuid [ref: > users.id]
  error_code varchar(20)
  created_at timestamptz [not null, default: `now()`]
  status_updated_at timestamptz

  Indexes {
    (conversation_id, created_at) [name: "messages_conversation_time_idx"]
    (wa_message_id) [name: "messages_wa_id_idx"]
    (workspace_id) [name: "messages_ws_idx"]
  }
}

Table conversation_notes {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null, ref: > conversations.id]
  user_id uuid [not null, ref: > users.id]
  content text [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (conversation_id) [name: "conversation_notes_conv_idx"]
  }
}

Table campaigns {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  phone_number_id uuid [not null, ref: > wa_phone_numbers.id]
  name varchar(100) [not null]
  template_id uuid [not null, ref: > templates.id]
  template_variables jsonb [default: '{}']
  status campaign_status [not null, default: 'draft']
  scheduled_at timestamptz
  sent_at timestamptz
  total_count int [default: 0]
  sent_count int [default: 0]
  delivered_count int [default: 0]
  read_count int [default: 0]
  failed_count int [default: 0]
  created_by uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id, status) [name: "campaigns_ws_status_idx"]
    (status, scheduled_at) [name: "campaigns_scheduled_idx", note: "partial index where status = 'scheduled'"]
  }
}

Table campaign_contacts {
  id uuid [pk, default: `gen_random_uuid()`]
  campaign_id uuid [not null, ref: > campaigns.id]
  contact_id uuid [not null, ref: > contacts.id]
  wa_message_id varchar(100)
  status campaign_contact_status [not null, default: 'pending']
  error_code varchar(20)
  sent_at timestamptz
  delivered_at timestamptz
  read_at timestamptz

  Indexes {
    (campaign_id, status) [name: "campaign_contacts_campaign_status_idx"]
    (wa_message_id) [name: "campaign_contacts_wa_id_idx"]
    (contact_id) [name: "campaign_contacts_contact_idx"]
  }
}

Table quick_replies {
  id uuid [pk, default: `gen_random_uuid()`]
  workspace_id uuid [not null, ref: > workspaces.id]
  title varchar(100) [not null]
  content text [not null]
  shortcut varchar(30)
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (workspace_id, shortcut) [unique, name: "quick_replies_ws_shortcut_idx", note: "partial index where shortcut is not null"]
    (workspace_id) [name: "quick_replies_ws_idx"]
  }
}
